        <mxCell id="ddl" value="&lt;b&gt;DdlDetector&lt;/b&gt;&#10;─────────────────────&#10;+ IsDdl(sql) → bool&#10;&#10;DDL keywords:&#10;CREATE, DROP, ALTER,&#10;TRUNCATE, VACUUM,&#10;PRAGMA, COPY..." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;overflow=auto;fontSize=11;" vertex="1" parent="1">
