  <diagram id="page2-read" name="2. Read Path (Query)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t2" value="Read Path: Query RPC — Cache Check → Shard → Pool → DuckDB → Stream" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="800" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="r1" value="1. Client sends&#10;Query(sql)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="2. QueryCache&#10;TryGet(sql)" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="70" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r2a" value="CACHE HIT&#10;Return cached responses&#10;~0.1ms latency" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="170" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="3. ShardedDuckDb&#10;next_for_read()&#10;idx++ % N" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="70" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r4" value="4. ConnectionPool&#10;Borrow()&#10;10s timeout" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="70" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r5" value="5. DuckDB Execute&#10;duckdb_query()&#10;(C++ Chunk API)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="70" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r6" value="6. Build Columnar Response&#10;&#10;For each chunk (2048 rows):&#10;• fill_column_from_vector()&#10;• memcpy fast path (no nulls)&#10;• Per-element + validity (nulls)&#10;• Arena allocation (C++)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="50" y="280" width="230" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="r7" value="7. Stream to Client&#10;&#10;writer-&gt;Write(response)&#10;per chunk&#10;(IsCancelled check)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="330" y="280" width="180" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r8" value="8. Cache Store&#10;&#10;cache.Put(sql, responses)&#10;For future cache hits" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="560" y="280" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r9" value="9. Return Connection&#10;&#10;Pool.Return(conn)&#10;(RAII Handle destructor)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="790" y="280" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="re1" edge="1" source="r1" target="r2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re2" value="miss" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="r2" target="r3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re2a" value="hit" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="r2" target="r2a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re3" edge="1" source="r3" target="r4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re4" edge="1" source="r4" target="r5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="r5" target="r6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re6" edge="1" source="r6" target="r7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re7" edge="1" source="r7" target="r8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re8" edge="1" source="r8" target="r9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page3-write" name="3. Write Path (Execute / BulkInsert)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t3" value="Write Path: Execute / BulkInsert — Fan-out → Batch → Merge → Transaction" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="800" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="w1" value="1. Client sends&#10;Execute(sql) or&#10;BulkInsert(table,data)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="w1b" value="BulkInsert only:&#10;Build INSERT SQL&#10;from columnar data&#10;(type dispatch + escape)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="160" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="w2" value="2. write_to_all(sql)&#10;&#10;Fan-out to ALL shards&#10;C#: Task.Run × N (parallel)&#10;C++: serial submit&#10;Rust: thread::scope" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="280" y="70" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Per-shard write pipeline -->
        <mxCell id="ws" value="PER-SHARD WRITE PIPELINE (WriteSerializer)" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="280" width="1050" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="ws1" value="3. Submit(sql)&#10;&#10;Enqueue request&#10;Block on DoneSignal&#10;(30s timeout)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;" vertex="1" parent="ws">
          <mxGeometry x="20" y="40" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="ws2" value="4. CollectBatch&#10;&#10;Wait for first request&#10;Then wait batch_ms (1ms)&#10;for more requests&#10;Max: batch_max (64)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="ws">
          <mxGeometry x="200" y="40" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="ws3" value="5. Classify&#10;&#10;DDL? (CREATE, DROP...)&#10;→ Execute individually&#10;&#10;DML? (INSERT, UPDATE...)&#10;→ Group for batching" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" vertex="1" parent="ws">
          <mxGeometry x="390" y="40" width="160" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ws4" value="6. MergeInserts&#10;&#10;Consecutive INSERTs to&#10;same table with same&#10;prefix → multi-row INSERT&#10;&#10;INSERT INTO t VALUES (1)&#10;INSERT INTO t VALUES (2)&#10;→ INSERT INTO t VALUES (1),(2)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="ws">
          <mxGeometry x="580" y="35" width="210" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="ws5" value="7. Transaction&#10;&#10;BEGIN&#10;Execute merged SQL(s)&#10;COMMIT&#10;&#10;If FAIL → ROLLBACK&#10;→ Retry individually" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;" vertex="1" parent="ws">
          <mxGeometry x="830" y="40" width="170" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="ws6" value="8. Signal Callers&#10;&#10;Set DoneSignal for&#10;each request in batch&#10;(unblocks Submit())" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;" vertex="1" parent="ws">
          <mxGeometry x="830" y="170" width="170" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="wse1" edge="1" source="ws1" target="ws2" parent="ws"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wse2" edge="1" source="ws2" target="ws3" parent="ws"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wse3" edge="1" source="ws3" target="ws4" parent="ws"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wse4" edge="1" source="ws4" target="ws5" parent="ws"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wse5" edge="1" source="ws5" target="ws6" parent="ws"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Cache invalidation -->
        <mxCell id="w8" value="9. Cache.Invalidate()&#10;Clear ALL cached results" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="670" width="240" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="w9" value="10. Return success&#10;to client" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="670" width="160" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="we1" edge="1" source="w1" target="w2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="we1b" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="w1" target="w1b" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="we2" edge="1" source="w2" target="ws" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="we3" edge="1" source="ws" target="w8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="we4" edge="1" source="w8" target="w9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page4-perf" name="4. Performance Optimizations">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t4" value="Performance Optimization Stack" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="35" as="geometry"/>
        </mxCell>

        <!-- Read Optimizations -->
        <mxCell id="ro" value="READ OPTIMIZATIONS" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="500" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="ro1" value="QueryCache (LRU + TTL)&#10;Cache hit: ~0.1ms vs 5-50ms DuckDB" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="ro">
          <mxGeometry x="20" y="35" width="220" height="40" as="geometry"/>
        </mxCell>
