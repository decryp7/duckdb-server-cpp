<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-07T00:00:00.000Z" agent="DuckDB gRPC Server" version="21.0.0">
  <diagram id="page1-overview" name="1. System Overview">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title1" value="DuckDB gRPC Server v5.1 — System Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- Client Layer -->
        <mxCell id="cl" value="CLIENT LAYER" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="70" width="900" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="c1" value="C# Client&#10;.NET 4.6.2&#10;Grpc.Core 2.46.6" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="cl">
          <mxGeometry x="30" y="35" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="Any gRPC Client&#10;Python / Go / Java&#10;Generated from .proto" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="cl">
          <mxGeometry x="220" y="35" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="c3" value="Benchmark Tool&#10;6 scenario types&#10;--quick / --full" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="cl">
          <mxGeometry x="430" y="35" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="c4" value="Admin / DBA&#10;Ping + GetStats&#10;Monitoring" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="cl">
          <mxGeometry x="620" y="35" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- gRPC Transport -->
        <mxCell id="grpc" value="gRPC / HTTP/2  —  proto/duckdb_service.proto  —  Port 19100&#10;&#10;Query (server-streaming)  |  Execute (unary)  |  BulkInsert (unary)  |  Ping (unary)  |  GetStats (unary)&#10;Columnar encoding: packed repeated fields per column (10 objects vs 11,000 per-cell)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="200" width="900" height="70" as="geometry"/>
        </mxCell>

        <!-- Server Layer -->
        <mxCell id="sl" value="SERVER LAYER (3 interchangeable implementations)" style="swimlane;startSize=25;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="300" width="900" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="s1" value="C# Server&#10;Grpc.Core 2.46.6&#10;DuckDB.NET 1.1.1&#10;VS2017 / .NET 4.6.2" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="sl">
          <mxGeometry x="30" y="30" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="C++ Server&#10;gRPC 1.35.0&#10;DuckDB C API (Chunk)&#10;Protobuf Arena alloc" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="sl">
          <mxGeometry x="260" y="30" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="Rust Server&#10;tonic 0.12 / prost 0.13&#10;duckdb 1.1 (bundled)&#10;query_arrow() zero-copy" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="sl">
          <mxGeometry x="490" y="30" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="All servers use&#10;identical architecture:&#10;Cache → Shard → Pool/Writer" style="text;whiteSpace=wrap;fontSize=10;fontStyle=2;align=center;" vertex="1" parent="sl">
          <mxGeometry x="710" y="35" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Query Cache -->
        <mxCell id="cache" value="QueryCache  (LRU + TTL 60s, Max 10K entries)&#10;Cache hit → bypass DuckDB entirely (~0.1ms)&#10;Invalidated on EVERY write (Execute / BulkInsert)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="430" width="600" height="55" as="geometry"/>
        </mxCell>

        <!-- ShardedDuckDb -->
        <mxCell id="sharded" value="ShardedDuckDb  (N independent database instances)&#10;READ: atomic round-robin (idx++ % N)  |  WRITE: fan-out to ALL shards (parallel)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="520" width="800" height="50" as="geometry"/>
        </mxCell>

        <!-- Shard 0 -->
        <mxCell id="sh0" value="Shard 0" style="swimlane;startSize=22;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="610" width="260" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="p0" value="ConnectionPool (N readers)&#10;Lock-free borrow/return&#10;10s timeout" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="sh0">
          <mxGeometry x="15" y="30" width="230" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="w0" value="WriteSerializer (1 writer thread)&#10;Batch window (1ms) + INSERT merge&#10;BEGIN...COMMIT transactions&#10;DDL runs outside transactions" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sh0">
          <mxGeometry x="15" y="85" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="t0" value="DuckDB Tuning:&#10;threads=1, preserve_insertion_order=false&#10;checkpoint_threshold=256MB&#10;late_materialization_max_rows=1000&#10;allocator_flush_threshold=128MB" style="text;whiteSpace=wrap;fontSize=9;fontStyle=0;align=left;fillColor=#f0f0f0;strokeColor=#cccccc;rounded=1;" vertex="1" parent="sh0">
          <mxGeometry x="15" y="155" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="db0" value="DuckDB&#10;Instance 0" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="sh0">
          <mxGeometry x="170" y="85" width="75" height="55" as="geometry"/>
        </mxCell>

        <!-- Shard 1 -->
        <mxCell id="sh1" value="Shard 1" style="swimlane;startSize=22;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="610" width="260" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="p1" value="ConnectionPool (N readers)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="sh1">
          <mxGeometry x="15" y="30" width="230" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="w1" value="WriteSerializer (1 writer)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sh1">
          <mxGeometry x="15" y="75" width="230" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="db1" value="DuckDB&#10;Instance 1" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="sh1">
          <mxGeometry x="80" y="130" width="100" height="55" as="geometry"/>
        </mxCell>

        <!-- Shard N-1 -->
        <mxCell id="sh2" value="..." style="text;align=center;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="670" y="700" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Shard N -->
        <mxCell id="shN" value="Shard N-1" style="swimlane;startSize=22;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="610" width="260" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="pN" value="ConnectionPool (N readers)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="shN">
          <mxGeometry x="15" y="30" width="230" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="wN" value="WriteSerializer (1 writer)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="shN">
          <mxGeometry x="15" y="75" width="230" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="dbN" value="DuckDB&#10;Instance N-1" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="shN">
          <mxGeometry x="80" y="130" width="100" height="55" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cl" target="grpc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="grpc" target="sl" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sl" target="cache" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cache" target="sharded" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
