<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!--
      Server GC mode: optimized for high-throughput server workloads.
      - Uses one GC thread per CPU core (instead of 1 shared thread)
      - Reduces GC pause times under high allocation pressure
      - Uses more memory but keeps latency lower
      - Critical for 100+ concurrent gRPC handlers
    -->
    <gcServer enabled="true" />

    <!--
      Concurrent GC: allows application threads to run during GC.
      Reduces pause times at the cost of slightly higher CPU usage.
    -->
    <gcConcurrent enabled="true" />
  </runtime>
</configuration>
