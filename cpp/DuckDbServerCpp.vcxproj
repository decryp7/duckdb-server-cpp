    </Link>
    <PreBuildEvent>
      <Command>if not exist "$(ProtoGenDir)" mkdir "$(ProtoGenDir)"
"$(GrpcRoot)\bin\protoc.exe" --cpp_out="$(ProtoGenDir)" --grpc_out="$(ProtoGenDir)" --plugin=protoc-gen-grpc="$(GrpcRoot)\bin\grpc_cpp_plugin.exe" --proto_path="$(SolutionDir)proto" duckdb_service.proto</Command>
      <Message>Generating C++ from duckdb_service.proto</Message>
    </PreBuildEvent>
    <PostBuildEvent>
      <Command>if exist "..\third_party\duckdb\lib\duckdb.dll" copy /Y "..\third_party\duckdb\lib\duckdb.dll" "$(OutDir)"</Command>
