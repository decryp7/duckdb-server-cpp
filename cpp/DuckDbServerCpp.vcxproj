    No vcpkg dependency.
  -->
  <PropertyGroup>
    <GrpcRoot Condition="'$(GRPC_ROOT)'==''">C:\grpc-install</GrpcRoot>
    <GrpcRoot Condition="'$(GRPC_ROOT)'!=''">$(GRPC_ROOT)</GrpcRoot>
    <ProtoGenDir>$(SolutionDir)cpp\generated</ProtoGenDir>
    <OutDir Condition="'$(Configuration)'=='Debug'">$(SolutionDir)cpp\bin\Debug\</OutDir>
    <IntDir Condition="'$(Configuration)'=='Debug'">$(SolutionDir)cpp\obj\Debug\</IntDir>
    <OutDir Condition="'$(Configuration)'=='Release'">$(SolutionDir)cpp\bin\Release\</OutDir>
